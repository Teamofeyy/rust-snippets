      "pub struct ${1:Name} {",
      "  pub ${2:field}: ${3:Type},",
      "}"
    ]
  },
  "Serde default struct": {
    "prefix": "serde-default-struct",
    "description": "Create a Serde struct implementing Default",
    "body": [
