  "Tokio select": {
    "prefix": "tokio-select",
    "description": "Create a tokio select block",
    "body": [
      "tokio::select! {",
      "  ${1:value} = ${2:future} => {",
      "    ${3}",
      "  }",
      "  _ = ${4:shutdown} => {",
      "    $0",
      "  }",
      "}"
    ]
  },
  "Tokio timeout": {
    "prefix": "tokio-timeout",
    "description": "Run a future with a timeout",
    "body": [
      "let ${1:result} = tokio::time::timeout(",
      "  std::time::Duration::from_${2:secs}(${3:30}),",
      "  ${4:future},",
      ")",
      ".await??;"
    ]
  },
  "Tokio sleep": {
    "prefix": "tokio-sleep",
