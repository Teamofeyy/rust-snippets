    "body": [
      "let mut ${1:interval} = tokio::time::interval(",
      "  std::time::Duration::from_${2:secs}(${3:1}),",
      ");",
      "",
      "loop {",
      "  ${1:interval}.tick().await;",
      "  $0",
      "}"
    ]
