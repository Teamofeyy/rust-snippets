  "Thiserror enum": {
    "prefix": "thiserror",
    "description": "Create an error enum using thiserror",
    "body": [
      "#[derive(Debug, thiserror::Error)]",
      "pub enum ${1:Error} {",
      "  #[error(\"${2:error message}\")]",
      "  ${3:Variant},",
      "",
      "  #[error(\"${4:operation failed}: {source}\")]",
      "  ${5:Source} {",
      "    #[source]",
      "    source: ${6:anyhow::Error},",
      "  },",
      "}"
    ]
  },
  "Thiserror transparent variant": {
    "prefix": "error-transparent",
    "description": "Create a transparent thiserror variant",
    "body": [
      "#[error(transparent)]",
      "${1:Variant}(#[from] ${2:Error}),"
    ]
  },
  "Thiserror source variant": {
    "prefix": "error-source",
    "description": "Create a thiserror variant with a source error",
    "body": [
      "#[error(\"${1:operation failed}: {source}\")]",
      "${2:Variant} {",
      "  #[source]",
      "  source: ${3:Error},",
      "},"
    ]
  },
  "Serde struct": {
    "prefix": "serde-struct",
    "description": "Create a serializable and deserializable struct",
    "body": [
