      "}"
    ]
  },
  "Serde tagged enum": {
    "prefix": "serde-tagged-enum",
    "description": "Create an internally tagged Serde enum",
    "body": [
      "#[derive(Debug, Clone, serde::Serialize, serde::Deserialize)]",
      "#[serde(tag = \"${1:type}\", rename_all = \"${2:snake_case}\")]",
      "pub enum ${3:Name} {",
      "  ${4:Variant} {",
      "    ${5:field}: ${6:Type},",
      "  },",
      "}"
    ]
  },
  "Serde rename field": {
    "prefix": "serde-rename",
    "description": "Rename a field during Serde serialization",
    "body": [
