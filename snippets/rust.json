  "Tokio spawn blocking": {
    "prefix": "tokio-spawn-blocking",
    "description": "Run a blocking operation using Tokio",
    "body": [
      "let ${1:result} = tokio::task::spawn_blocking(move || {",
      "  $0",
      "})",
      ".await??;"
